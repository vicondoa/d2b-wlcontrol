// nixling-wlcontrol — optional niri window rule for the control center.
//
// Add this block to your niri config (`window-rules` section) so the control
// center opens as a tidy floating window instead of tiling. The app-id is set
// by the GTK application (Wave 2).

window-rule {
    match app-id="dev.vicondoa.NixlingWlControl"

    open-floating true
    default-column-width { fixed 520; }
    default-window-height { fixed 640; }
}
